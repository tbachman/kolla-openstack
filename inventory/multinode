# multinode inventory — distribute services across dedicated hosts.
# Replace the placeholder IPs with your actual host addresses.
# All hosts must be SSH-reachable from the deployment host.
#
# Minimal HA layout:
#   3 × controller  (control, network, storage, monitoring)
#   N × compute     (compute)

[control]
controller01  ansible_host=192.168.100.11 ansible_user=ubuntu ansible_become=true
controller02  ansible_host=192.168.100.12 ansible_user=ubuntu ansible_become=true
controller03  ansible_host=192.168.100.13 ansible_user=ubuntu ansible_become=true

[network:children]
control

[storage:children]
control

[monitoring:children]
control

[compute]
compute01     ansible_host=192.168.100.21 ansible_user=ubuntu ansible_become=true
compute02     ansible_host=192.168.100.22 ansible_user=ubuntu ansible_become=true
# add more compute nodes here

[deployment]
localhost     ansible_connection=local

# ── Optional: dedicated storage nodes ────────────────────────────────────────
# Uncomment and populate if you want separate Ceph OSD / Cinder-volume nodes.
