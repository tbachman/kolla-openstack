# all-in-one inventory — all OpenStack services run on a single host.
# For a remote host replace "localhost" with the target IP/hostname and
# set ansible_user / ansible_ssh_private_key_file as needed.

[control]
localhost       ansible_connection=local

[network]
localhost       ansible_connection=local

[compute]
localhost       ansible_connection=local

[monitoring]
localhost       ansible_connection=local

[storage]
localhost       ansible_connection=local

[deployment]
localhost       ansible_connection=local

